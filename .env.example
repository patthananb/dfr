FIRMWARE_HMAC_SECRET=your-secret-here

# Prisma / database connection.
# SQLite (default, zero-ops). Relative paths resolve from prisma/schema.prisma,
# so ../data/dfr.db lands the db next to the fault JSON files under /data.
DATABASE_URL="file:../data/dfr.db"
# Postgres (uncomment + populate when scaling horizontally):
# DATABASE_URL="postgresql://dfr:dfr@db:5432/dfr?schema=public"
